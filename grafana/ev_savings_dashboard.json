      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${DS_TESLAMATE}"
          },
          "format": "table",
          "rawSql": "WITH elec AS (\n  SELECT COALESCE(\n    SUM(cost) / NULLIF(SUM(charge_energy_added), 0),\n    ${electricity_price}::numeric\n  ) as price_per_kwh\n  FROM charging_processes\n  WHERE car_id = ${car_id}\n    AND cost IS NOT NULL\n    AND charge_energy_added > 0\n)\nSELECT\n  TO_CHAR(d.start_date AT TIME ZONE 'Europe/Rome', 'DD/MM/YY HH24:MI') as \"Date\",\n  COALESCE(sg.name, sa.name, 'Unknown') || ' → ' || COALESCE(eg.name, ea.name, 'Unknown') as \"Route\",\n  d.id as \"drive_id\",\n  TO_CHAR(d.start_date AT TIME ZONE 'UTC', 'YYYY-MM-DD\"T\"HH24:MI:SS.000\"Z\"') as \"from\",\n  TO_CHAR(COALESCE(d.end_date, d.start_date + interval '1 hour') AT TIME ZONE 'UTC', 'YYYY-MM-DD\"T\"HH24:MI:SS.000\"Z\"') as \"to\",\n  ROUND(d.distance::numeric, 1) as \"Distance\",\n  ROUND(GREATEST((d.start_rated_range_km - d.end_rated_range_km) * c.efficiency, 0)::numeric, 2) as \"kWh Used\",\n  CASE WHEN d.distance > 0\n    THEN ROUND((GREATEST(d.start_rated_range_km - d.end_rated_range_km, 0) * c.efficiency * 1000 / d.distance)::numeric, 0)\n    ELSE 0\n  END as \"Wh/km\",\n  ROUND((GREATEST((d.start_rated_range_km - d.end_rated_range_km) * c.efficiency, 0) * e.price_per_kwh)::numeric, 2) as \"EV Cost\",\n  ROUND(((d.distance / 100.0) * ${ice_consumption} * fp.price_per_liter)::numeric, 2) as \"Gas Cost\",\n  ROUND((\n    (d.distance / 100.0) * ${ice_consumption} * fp.price_per_liter\n    - GREATEST((d.start_rated_range_km - d.end_rated_range_km) * c.efficiency, 0) * e.price_per_kwh\n  )::numeric, 2) as \"Savings\",\n  fp.price_per_liter as \"Fuel Price\"\nFROM drives d\nJOIN cars c ON c.id = d.car_id\nCROSS JOIN elec e\nLEFT JOIN addresses sa ON d.start_address_id = sa.id\nLEFT JOIN addresses ea ON d.end_address_id = ea.id\nLEFT JOIN geofences sg ON d.start_geofence_id = sg.id\nLEFT JOIN geofences eg ON d.end_geofence_id = eg.id\nJOIN LATERAL (\n  SELECT price_per_liter FROM fuel_prices\n  WHERE week_start <= d.start_date::date\n  ORDER BY week_start DESC LIMIT 1\n) fp ON true\nWHERE d.car_id = ${car_id}\n  AND d.distance > 0\n  AND d.start_date >= $__timeFrom()\n  AND d.start_date <= $__timeTo()\nORDER BY d.start_date DESC",
          "refId": "A"
        }
      ],
