        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${DS_TESLAMATE}"
          },
          "format": "table",
          "rawSql": "WITH elec AS (\n  SELECT COALESCE(\n    SUM(cost) / NULLIF(SUM(charge_energy_added), 0),\n    ${electricity_price}::numeric\n  ) as price_per_kwh\n  FROM charging_processes\n  WHERE car_id = ${car_id}\n    AND cost IS NOT NULL\n    AND charge_energy_added > 0\n)\nSELECT\n  SUM(\n    (d.distance / 100.0) * ${ice_consumption} * fp.price_per_liter\n    - GREATEST((d.start_rated_range_km - d.end_rated_range_km) * c.efficiency, 0) * e.price_per_kwh\n  ) as \"Total Savings\"\nFROM drives d\nJOIN cars c ON c.id = d.car_id\nCROSS JOIN elec e\nJOIN LATERAL (\n  SELECT price_per_liter FROM fuel_prices\n  WHERE week_start <= d.start_date::date\n  ORDER BY week_start DESC LIMIT 1\n) fp ON true\nWHERE d.car_id = ${car_id}\n  AND d.distance > 0\n  AND d.start_date >= $__timeFrom()\n  AND d.start_date <= $__timeTo()",
          "refId": "A"
        }
      ],
      "title": "Total Savings",
      "type": "stat"
    },
