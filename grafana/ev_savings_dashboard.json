          "format": "time_series",
          "rawSql": "WITH elec AS (\n  SELECT COALESCE(\n    SUM(cost) / NULLIF(SUM(charge_energy_added), 0),\n    ${electricity_price}::numeric\n  ) as price_per_kwh\n  FROM charging_processes\n  WHERE car_id = ${car_id}\n    AND cost IS NOT NULL\n    AND charge_energy_added > 0\n),\ndrive_costs AS (\n  SELECT\n    d.start_date as time,\n    GREATEST((d.start_rated_range_km - d.end_rated_range_km) * c.efficiency, 0) * e.price_per_kwh as ev_cost,\n    (d.distance / 100.0) * ${ice_consumption} * fp.price_per_liter as gas_cost\n  FROM drives d\n  JOIN cars c ON c.id = d.car_id\n  CROSS JOIN elec e\n  JOIN LATERAL (\n    SELECT price_per_liter FROM fuel_prices\n    WHERE week_start <= d.start_date::date\n    ORDER BY week_start DESC LIMIT 1\n  ) fp ON true\n  WHERE d.car_id = ${car_id}\n    AND d.distance > 0\n    AND d.start_date >= $__timeFrom()\n    AND d.start_date <= $__timeTo()\n)\nSELECT\n  time,\n  SUM(ev_cost) OVER (ORDER BY time) as \"Cumulative EV Cost\",\n  SUM(gas_cost) OVER (ORDER BY time) as \"Cumulative Gas Cost\",\n  SUM(gas_cost - ev_cost) OVER (ORDER BY time) as \"Cumulative Savings\"\nFROM drive_costs\nORDER BY time",
          "refId": "A"
        }
      ],
      "title": "Cumulative Savings Over Time",
      "type": "timeseries"
